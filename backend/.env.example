# 复制为 .env 后按需修改。镜像（可选，与 pip.conf / pyproject [tool.uv.index] 二选一即可）
# pip 环境变量（未设置 PIP_CONFIG_FILE=pip.conf 时可用）
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

APP_ENV=development
LOG_LEVEL=INFO

# 本地 Widget 免 portal JWT：与 frontend/.env.development 的 VITE_DEV_WIDGET_AUTH_BYPASS 一起使用。
# 生产环境必须 false 或未设置（勿在公网开启）。
DEV_WIDGET_AUTH_BYPASS=true

# 无真实模型密钥/内网不通时避免 chat SSE 报 MODEL_UNAVAILABLE（502）：仅 development 生效。
MODEL_DEV_MOCK=true

DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:55432/agent_factory
REDIS_URL=redis://localhost:56379/0

MINIO_ENDPOINT=localhost:59000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agent-factory
MINIO_USE_SSL=false

JWT_SECRET=change-me-in-production-use-long-random-string
PORTAL_JWT_SECRET=portal-dev-secret-must-match-portal-mock
USER_ID_HASH_SALT=dev-salt-change-in-production

SESSION_COOKIE_SECURE=false

# MAU retention gate（prd §15.1；默认关闭以免开发库无流量时种子 Agent 被标 cold）
# MAU_RETENTION_GATE_ENABLED=false
# MAU_RETENTION_WINDOW_DAYS=30
# MAU_RETENTION_DEFAULT_THRESHOLD=5
# MAU_COLD_ARCHIVE_AFTER_DAYS=90

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 运维 Bearer：本地可自拟任意非空字符串（非平台颁发）；写入后重启后端。
# 用于 POST/PUT /api/v1/agents、/api/v1/skills、脚本 sync_agents_from_repo.py、
# sync_skills_from_repo.py、部分 admin 接口。
# 留空则仅靠会话 Cookie（agent.write）调用注册接口；纯降级/审计接口仍可能 503。
ADMIN_API_TOKEN=123456

# RBAC（docs/51）：agent.admin 是否自动展开 skill.publish 等；权限快照建议周期（秒），GET /auth/me 披露。
# RBAC_LEGACY_AGENT_ADMIN_IMPLIES_FULL=true
# RBAC_PERMISSION_CACHE_SECONDS=300

# MiniMax（models.yaml 默认 endpoint：https://api.minimaxi.com/v1 国内站；国际密钥改用 https://api.minimax.io/v1）
# 可写在仓库根目录 .env 或本文件 backend/.env（两处都存在时以后者为准）
# MINIMAX_API_KEY=

# Skill 入库评测门禁（package_metadata.eval_cases 非空时）
# SKILL_EVAL_GATE_LIVE=false
# SKILL_EVAL_GATE_MODEL=
# 评测路径每分钟上限（Redis）；0=沿用 models.yaml 中该模型的 rpm
# SKILL_EVAL_GATE_RPM=0
# 为 true 时（默认）POST/PUT /skills 必须带至少一条 eval_cases 或 evals_inline（prd §8.5）
# SKILL_EVAL_CASES_REQUIRED=true

# Tool Registry 中 implementation.type=http_api 时的出站 URL 前缀白名单（逗号分隔）。
# 为空则禁用此类调用（内置 kb.search 等不受影响）。详见 docs/31、docs/09。
# INTERNAL_HTTP_TOOL_URL_PREFIXES=https://api.internal.company/
# INTERNAL_HTTP_TOOL_BEARER_TOKEN=

# Workspace tools (OpenClaw / Claude Code-style fs.*, shell.exec, web.fetch)
# WORKSPACE_TOOLS_ENABLED=true
# WORKSPACE_ROOT=/path/to/sandbox
# SHELL_EXEC_ENABLED=true
# WEB_FETCH_ENABLED=true
# WEB_FETCH_URL_PREFIXES=http://,https://

# MCP servers (Context7 + Playwright, OpenClaw bundle-mcp parity)
# MCP_CONTEXT7_ENABLED=true
# MCP_CONTEXT7_COMMAND=npx
# MCP_CONTEXT7_ARGS=-y,@upstash/context7-mcp@latest
# MCP_PLAYWRIGHT_ENABLED=true
# MCP_PLAYWRIGHT_COMMAND=npx
# MCP_PLAYWRIGHT_ARGS=-y,@playwright/mcp@latest
# MCP_CALL_TIMEOUT_SECONDS=60

# OpenClaw runtime tools (memory / sessions / ui / automation / media)
# MEMORY_TOOLS_ENABLED=true
# MEMORY_GET_DEFAULT_LINES=200
# SESSIONS_TOOLS_ENABLED=true
# SESSIONS_HISTORY_MAX_CHARS=80000
# UI_TOOLS_ENABLED=true
# AUTOMATION_TOOLS_ENABLED=true
# MEDIA_TOOLS_ENABLED=true
# MEDIA_VISION_MODEL=
# MEDIA_IMAGE_GENERATE_URL=
# MEDIA_IMAGE_GENERATE_API_KEY=
# CODE_EXECUTION_ENABLED=true
# CODE_EXECUTION_LLM_FALLBACK=true
# CODE_EXECUTION_URL=

# X (Twitter) search + messaging + nodes
# WEB_X_SEARCH_ENABLED=true
# X_SEARCH_API_URL=
# MESSAGING_TOOLS_ENABLED=true
# NODES_TOOLS_ENABLED=true
# MEDIA_MUSIC_GENERATE_URL=
# MEDIA_VIDEO_GENERATE_URL=
# MEDIA_TTS_URL=
# MEDIA_TTS_OPENAI_COMPAT=https://api.openai.com/v1
# MEDIA_TTS_API_KEY=
# MEDIA_TTS_MODEL=tts-1
# MEDIA_TTS_VOICE=alloy

# Baidu Qianfan web.search (web.search tool)
# WEB_SEARCH_ENABLED=true
# BAIDU_WEB_SEARCH_API_KEY=bce-v3/ALTAK-xxx/xxx
# BAIDU_WEB_SEARCH_URL=https://qianfan.baidubce.com/v2/ai_search/web_search
# BAIDU_WEB_SEARCH_DEFAULT_TOP_K=10
# BAIDU_WEB_SEARCH_EDITION=standard

# External knowledge service for kb.search (POST JSON: query, retrieval_scopes, optional scope)
# KB_SEARCH_URL=https://kb.internal/api/search
# KB_SEARCH_BEARER_TOKEN=
# KB_SEARCH_TIMEOUT_SECONDS=12
# 出站 kb.search URL：默认仅 https；内网 http 实验可开（生产勿用）
# KB_SEARCH_ALLOW_HTTP=false
# 是否允许 KB_SEARCH_URL 使用私网/回环字面 IP（仅隔离实验网）
# KB_SEARCH_ALLOW_PRIVATE_HOSTS=false
# KB_SEARCH_REQUIRE_UPSTREAM=false

# Partner risk.rule_check HTTP (optional; built-in rules when empty)
# RISK_RULE_CHECK_URL=https://risk.internal/api/check
# RISK_RULE_CHECK_BEARER_TOKEN=
# RISK_RULE_CHECK_TIMEOUT_SECONDS=15

# POST /api/v1/skills/import-git (requires git on server PATH)
# SKILL_GIT_IMPORT_ENABLED=true

# P2 受控脚本（默认 false 保持 P0 script_hooks={}）
# SCRIPT_HOOKS_ENABLED=true
# SCRIPT_WORKER_RUNTIME=auto
# SCRIPT_GVISOR_RUNSC=/usr/local/bin/runsc
# SCRIPT_GVISOR_ROOTLESS=true

# P3 工作流 DAG / multi-skill / Router（默认 true）
# WORKFLOW_DAG_ENABLED=true
# MULTI_SKILL_ENABLED=true
# ROUTER_AGENT_ENABLED=true
# ROUTER_USE_LLM=true
# ROUTER_MODEL=MiniMax-M2.7
# ROUTER_LLM_MAX_TOKENS=256

# 认证相关接口（exchange/session/sync-permissions）每 IP 每分钟上限（防爆破）
# AUTH_RATE_LIMIT_PER_MINUTE=20

# 用户消息 Unicode 清洗后最大字符数、每会话每分钟 chat 次数上限（防滥用）
# CHAT_USER_MESSAGE_MAX_CHARS=32000
# CHAT_RATE_LIMIT_PER_SESSION_PER_MINUTE=45

# 仅 HTTPS 生产环境可设 HSTS（秒）；0=不发送 Strict-Transport-Security
# HSTS_MAX_AGE_SECONDS=0

# POST .../chat 会话锁：同会话并发请求时在 Redis 中有界等待（plan §12）。
# SESSION_CHAT_LOCK_MAX_WAITERS=8
# SESSION_CHAT_LOCK_WAIT_MS=45000
# SESSION_CHAT_LOCK_POLL_MS=150

# 模型网关多队列骨架（docs/10）：按类限制并行 HTTP；embedding 池预留给向量/Rerank。
# MODEL_QUEUE_ENABLED=true
# MODEL_QUEUE_CAP_PRIVILEGED=32
# MODEL_QUEUE_CAP_INTERACTIVE=64
# MODEL_QUEUE_CAP_DOCUMENT=24
# MODEL_QUEUE_CAP_BATCH=16
# MODEL_QUEUE_CAP_EMBEDDING=32
# MODEL_QUEUE_ACQUIRE_TIMEOUT_MS=120000
# MODEL_QUEUE_POLL_MS=50
# ZSET 等待条数上限（docs/10 队列容量）
# MODEL_QUEUE_MAX_ZQUEUE_PRIVILEGED=100
# MODEL_QUEUE_MAX_ZQUEUE_INTERACTIVE=1000
# MODEL_QUEUE_MAX_ZQUEUE_DOCUMENT=500
# MODEL_QUEUE_MAX_ZQUEUE_BATCH=2000
# ZCARD 软上限 → POST …/chat 预检 429 + Retry-After（docs/10）
# MODEL_QUEUE_SOFT_ZCARD_INTERACTIVE=900
# MODEL_QUEUE_SOFT_ZCARD_DOCUMENT=450
# MODEL_QUEUE_SOFT_ZCARD_PRIVILEGED=98
# MODEL_QUEUE_RETRY_AFTER_INTERACTIVE=5
# MODEL_QUEUE_RETRY_AFTER_DOCUMENT=30
# MODEL_QUEUE_RETRY_AFTER_PRIVILEGED=10
# 优先级老化（秒 / ZINCRBY 增量，docs/10）
# MODEL_QUEUE_AGING_SEC_1=30
# MODEL_QUEUE_AGING_SEC_2=60
# MODEL_QUEUE_AGING_SEC_3=120
# MODEL_QUEUE_AGING_DELTA_1=100000000000000
# MODEL_QUEUE_AGING_DELTA_2=100000000000000
# MODEL_QUEUE_AGING_FORCE_DELTA=5000000000000000

# Embedding 批合并（docs/10；kb.search 异步路径）
# EMBEDDING_ENDPOINT=
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_BATCH_WINDOW_MS=100
# EMBEDDING_BATCH_MAX_ITEMS=64
# EMBEDDING_HTTP_TIMEOUT_SECONDS=60

# 降级自动恢复（docs/13；默认关闭，与 cron_scheduler 60s tick 对齐）
# DEGRADATION_AUTO_ENABLED=false
# DEGRADATION_AUTO_WINDOW_MINUTES=3
# DEGRADATION_AUTO_ESCALATE_ERROR_RATE=0.05
# DEGRADATION_AUTO_RECOVER_MAX_ERROR_RATE=0.01
# DEGRADATION_AUTO_GOOD_STREAK_SECONDS=300
# DEGRADATION_AUTO_LATENCY_ESCALATE_MS=30000
# DEGRADATION_AUTO_LATENCY_RECOVER_MS=8000
# DEGRADATION_AUTO_MIN_ATTEMPTS_FOR_RECOVER=8
# prd §9.5 延迟分档：60s 降 top_k、120s 可切小模型（models.yaml 逻辑名）
# DEGRADATION_LATENCY_REDUCE_TOPK_MS=60000
# DEGRADATION_LATENCY_SMALL_MODEL_MS=120000
# DEGRADATION_KB_TOP_K_REDUCED=5
# DEGRADATION_MAX_TURNS_ON_ERROR_ESCALATION=3
# DEGRADATION_CHAT_SMALL_MODEL=

# Registry http_api 工具熔断（Redis；可按 tools.rate_limit.circuit_breaker 覆盖）。
# TOOL_HTTP_CIRCUIT_ENABLED=true
# TOOL_HTTP_CIRCUIT_FAILURE_THRESHOLD=5
# TOOL_HTTP_CIRCUIT_WINDOW_SECONDS=60
# TOOL_HTTP_CIRCUIT_OPEN_SECONDS=30
# TOOL_HTTP_CIRCUIT_PER_DEPARTMENT=true

# 上传超过该字节数时投递 mq:doc_jobs（文档解析 Worker，docs/24）。
# DOC_PARSE_ASYNC_MIN_BYTES=10485760
# 文档解析队列长度超过该值时任意大小上传也投递异步解析（prd §9.5）。
# DOC_PARSE_QUEUE_FORCE_ASYNC_DEPTH=100

# 飞书 / Lark 机器人通道（参考 OpenClaw feishu plugin）
# 在飞书开放平台创建企业自建应用，开通机器人 + 消息接收（长连接或 webhook）
# FEISHU_ENABLED=false
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=
# FEISHU_CONNECTION_MODE=ws
# FEISHU_DOMAIN=feishu
# FEISHU_DEFAULT_AGENT_ID=demo-agent
# FEISHU_CANDIDATE_AGENT_IDS=work-summary-agent,meeting-minutes-agent,contract-to-plan-agent
# FEISHU_GROUP_REQUIRE_MENTION=true   # 群聊是否必须 @机器人（同步到 lark-oapi PolicyConfig）
# FEISHU_DM_POLICY=open
# FEISHU_ROUTE_EACH_TURN=false
# FEISHU_ROUTER_USE_LLM=true
# FEISHU_REPLY_USE_MARKDOWN=true   # 以卡片形式渲染 Markdown（标题/加粗/表格等）
# FEISHU_CHANNEL_EXTRA_TOOLS=feishu.doc,agent.list   # 飞书会话额外注入的工具
# FEISHU_MAX_TURNS=0   # 0=单条消息内最多约64轮工具循环；飞书同一会话可连续多天聊天
# FEISHU_SESSION_TTL_DAYS=30   # 同一飞书群/私聊绑定会话时长（天）
# 飞书应用还需开通权限：docx:document、docx:document.block:convert、drive:drive
# Webhook 模式：事件订阅 URL 填 https://<your-host>/api/v1/feishu/events

# OpenTelemetry traces（可选；需 uv sync --extra observability，docs/31、docs/32）
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=agent-factory-api
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_TRACES_SAMPLER_RATIO=1.0
